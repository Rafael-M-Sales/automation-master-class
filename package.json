{
  "name": "automation-master-class",
  "version": "1.0.0",
  "description": "Projeto Master Class de Automação: Playwright + BDD + SQS + Jenkins",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js features/**/*.feature",
    "test:api": "playwright test tests/api",
    "test:headed": "cross-env HEADLESS=false npm test",
    "test:ui": "playwright test tests/ui",
    "infra:up": "node scripts/ensure-docker.js && docker-compose up -d",
    "infra:down": "docker-compose down",
    "infra:logs": "docker-compose logs -f",
    "watch:git": "node scripts/git-sync.js",
    "postinstall": "npx playwright install chromium"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.0.0",
    "@cucumber/cucumber": "^10.0.0",
    "axios": "^1.6.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "playwright": "^1.40.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "chokidar": "^5.0.0"
  }
}
